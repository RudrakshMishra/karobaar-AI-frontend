generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  clerk_id           String?             @unique
  email              String              @unique
  full_name          String?
  store_name         String?
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  onboarding         OnboardingProfile?
  products           Product[]
  orders             Order[]
  competitor_links   CompetitorLink[]
  ai_suggestions     AiSuggestion[]
}

model OnboardingProfile {
  id                 String   @id @default(uuid())
  user_id            String   @unique
  platforms          String[]
  monthly_revenue    String?
  profit_goal        String?
  gst_percent        Float    @default(18.0)
  return_rate_percent Float   @default(15.0)
  shipping_cost      Float    @default(50.0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  user               User     @relation(fields: [user_id], references: [id])
}

model Product {
  id                 String   @id @default(uuid())
  user_id            String
  sku                String
  name               String
  cost               Float    @default(0)
  current_price      Float    @default(0)
  current_stock      Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  user               User     @relation(fields: [user_id], references: [id])
  pricing_history    PricingHistory[]
}

model Order {
  id                 String   @id @default(uuid())
  user_id            String
  external_order_id  String?
  platform           String
  status             String
  total_amount       Float
  ordered_at         DateTime
  created_at         DateTime @default(now())
  user               User     @relation(fields: [user_id], references: [id])
}

model CompetitorLink {
  id                 String   @id @default(uuid())
  user_id            String
  product_id         String
  url                String
  platform           String
  last_checked_price Float?
  last_checked_at    DateTime?
  created_at         DateTime @default(now())
  user               User     @relation(fields: [user_id], references: [id])
}

model PricingHistory {
  id                 String   @id @default(uuid())
  product_id         String
  old_price          Float
  new_price          Float
  changed_at         DateTime @default(now())
  reason             String?
  product            Product  @relation(fields: [product_id], references: [id])
}

model AiSuggestion {
  id                 String   @id @default(uuid())
  user_id            String
  type               String
  priority           String
  title              String
  description        String
  action             String?
  status             String   @default("active")
  created_at         DateTime @default(now())
  applied_at         DateTime?
  dismissed_at       DateTime?
  user               User     @relation(fields: [user_id], references: [id])
}
